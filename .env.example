# Firebase Admin service account values. Add these in Vercel Project Settings > Environment Variables.
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# Use a strong unique password and a separate random signing secret.
ADMIN_PASSWORD=
ADMIN_SESSION_SECRET=

# Google Workspace SMTP values for contact-form delivery.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=info@noon-sprachdienst.de
SMTP_PASSWORD=replace-with-google-app-password
CONTACT_EMAIL=info@noon-sprachdienst.de
